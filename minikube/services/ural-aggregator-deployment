apiVersion: apps/v1
kind: Deployment
metadata:
  name: ural-aggregator
spec:
  replicas: 1
  selector:
    matchLabels:
      app: ural-aggregator
  template:
    metadata:
      labels:
        app: ural-aggregator
    spec:
      containers:
        - name: ural-aggregator
          image: kerzhakovn/ural-aggregator-service:latest
          ports:
            - containerPort: 8080
          env:
            - name: SERVER_PORT
              value: "8080"
            - name: PUBLIC_KEY
              value: ""
            - name: PROXY_CARGO_URL
              value: "http://localhost:10001"
            - name: PROXY_USERS_URL
              value: "http://localhost:10002"
            - name: PROXY_AUTH_URL
              value: "http://localhost:10003"
            - name: LOGGING_LEVEL_ROOT
              value: "info"

---
apiVersion: v1
kind: Service
metadata:
  name: ural-aggregator
spec:
  type: ClusterIP
  selector:
    app: ural-aggregator
  ports:
    - port: 10000 
      targetPort: 8080 