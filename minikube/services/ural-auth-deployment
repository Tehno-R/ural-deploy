apiVersion: apps/v1
kind: Deployment
metadata:
  name: ural-auth
  namespace: dev
spec:
  replicas: 1
  selector:
    matchLabels:
      app: ural-auth
  template:
    metadata:
      labels:
        app: ural-auth
    spec:
      containers:
        - name: ural-auth
          image: kerzhakovn/ural-auth-service:latest
          ports:
            - containerPort: 8080
          env:
            - name: SERVER_PORT
              value: "8080"
            - name: DB_URL
              value: "jdbc:postgresql://postgres:5432"
            - name: DB_NAME
              value: "ural"
            - name: DB_USER
              value: "postgres"
            - name: DB_PASS
              value: "postgres"
            - name: SHOW_SQL
              value: "false"
            - name: REFRESH_TOKEN_EXPIRED_ON_SECONDS
              value: "604800"
            - name: ACCESS_TOKEN_EXPIRED_ON_SECONDS
              value: "300"
            - name: PUBLIC_KEY
              value: ""
            - name: PRIVATE_KEY
              value: ""
            - name: LOGGING_LEVEL_ROOT
              value: "info"
          imagePullPolicy: Always


---
apiVersion: v1
kind: Service
metadata:
  name: ural-auth
  namespace: dev
spec:
  type: ClusterIP
  selector:
    app: ural-auth
  ports:
    - port: 10006 
      targetPort: 8080 