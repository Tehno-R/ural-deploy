apiVersion: apps/v1
kind: Deployment
metadata:
  name: ural-front
  namespace: dev
spec:
  replicas: 1
  selector:
    matchLabels:
      app: ural-front
  template:
    metadata:
      labels:
        app: ural-front
    spec:
      containers:
        - name: ural-front
          image: kerzhakovn/ural-front:latest
          ports:
            - containerPort: 80
          imagePullPolicy: Always


---
apiVersion: v1
kind: Service
metadata:
  name: ural-front
  namespace: dev
spec:
  type: NodePort
  selector:
    app: ural-front
  ports:
    - port: 8080 
      targetPort: 80
      NodePort: 80 